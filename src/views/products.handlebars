<section class="products-page">
  <div class="page-heading">
    <div>
      <p class="eyebrow">Catálogo</p>
      <h1>Productos</h1>

      <p>
        Se encontraron
        <strong>{{totalProducts}}</strong>
        productos.
      </p>
    </div>
  </div>

  <form
    class="products-filters"
    action="/products"
    method="GET"
  >
    <div class="form-field">
      <label for="query">
        Categoría o disponibilidad
      </label>

      <input
        id="query"
        name="query"
        type="text"
        value="{{currentQuery}}"
        placeholder="Ej.: Audio o available"
      />
    </div>

    <div class="form-field">
      <label for="sort">Orden por precio</label>

      <select id="sort" name="sort">
        <option value="">
          Sin ordenar
        </option>

        <option value="asc">
          Menor a mayor
        </option>

        <option value="desc">
          Mayor a menor
        </option>
      </select>
    </div>

    <div class="form-field">
      <label for="limit">
        Productos por página
      </label>

      <select id="limit" name="limit">
        <option value="6">6</option>
        <option value="10">10</option>
        <option value="12">12</option>
      </select>
    </div>

    <div class="filter-actions">
      <button class="button" type="submit">
        Aplicar filtros
      </button>

      <a
        class="button button-secondary"
        href="/products"
      >
        Limpiar
      </a>
    </div>
  </form>

  {{#if hasProducts}}
    <div class="products-grid">
      {{#each products}}
        <article class="product-card">
          <div class="product-image">
            {{#if thumbnails.length}}
              <img
                src="{{thumbnails.[0]}}"
                alt="{{title}}"
              />
            {{else}}
              <span>Sin imagen</span>
            {{/if}}
          </div>

          <div class="product-content">
            <div class="product-meta">
              <span class="category">
                {{category}}
              </span>

              {{#if isAvailable}}
                <span class="status available">
                  {{availabilityText}}
                </span>
              {{else}}
                <span class="status unavailable">
                  {{availabilityText}}
                </span>
              {{/if}}
            </div>

            <h2>{{title}}</h2>

            <p class="product-description">
              {{description}}
            </p>

            <p class="product-stock">
              Stock: {{stock}}
            </p>

            <div class="product-footer">
              <strong class="product-price">
                {{formattedPrice}}
              </strong>

              <a
                class="detail-link"
                href="/products/{{_id}}"
              >
                Ver detalle
              </a>
            </div>
          </div>
        </article>
      {{/each}}
    </div>

    <nav
      class="pagination"
      aria-label="Paginación"
    >
      {{#if hasPrevPage}}
        <a
          class="pagination-link"
          href="{{prevLink}}"
        >
          ← Anterior
        </a>
      {{else}}
        <span
          class="pagination-link disabled"
        >
          ← Anterior
        </span>
      {{/if}}

      <span class="pagination-current">
        Página {{page}} de {{totalPages}}
      </span>

      {{#if hasNextPage}}
        <a
          class="pagination-link"
          href="{{nextLink}}"
        >
          Siguiente →
        </a>
      {{else}}
        <span
          class="pagination-link disabled"
        >
          Siguiente →
        </span>
      {{/if}}
    </nav>
  {{else}}
    <div class="empty-state">
      <h2>No encontramos productos</h2>

      <p>
        Probá modificando el filtro o volviendo
        al catálogo completo.
      </p>

      <a class="button" href="/products">
        Ver todos
      </a>
    </div>
  {{/if}}
</section>

<script>
  document.getElementById("sort").value = "{{currentSort}}";

  document.getElementById("limit").value = "{{currentLimit}}";
</script>